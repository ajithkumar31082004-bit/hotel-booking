# =============================================================================
# Blissful Abodes Chennai - Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to Git.
# =============================================================================

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=my_super_secret_hotel_key_123

# ── AWS Core ─────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# NOTE: If your EC2 has an IAM Role attached, you do NOT need these keys.
# Leave blank if using IAM Role (recommended). Only fill if testing locally.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Amazon S3 + CloudFront (Feature 1) ───────────────────────────────────────
S3_BUCKET_NAME=blissful-abodes-media
# After creating your CloudFront distribution, paste the domain here:
CLOUDFRONT_URL=d2uedlx8seh0kg.cloudfront.net

# ── Amazon SES Email (Feature 2) ─────────────────────────────────────────────
# Must be a verified SES identity (domain or email address)
SES_FROM_EMAIL=noreply@blissfulabodes.com

# ── Amazon SNS SMS (Feature 3) ───────────────────────────────────────────────
SNS_SENDER_ID=BLISSFUL

# ── Amazon ElastiCache Redis (Feature 4) ─────────────────────────────────────
# Format: your-cluster.xxxxx.cfg.apse1.cache.amazonaws.com
REDIS_HOST=
REDIS_PORT=6379

# ── Amazon Rekognition / Comprehend / Polly (Features 5, 6, 8) ───────────────
# These use the same AWS credentials above – no extra config needed.

# ── AWS Secrets Manager (Feature 10) ─────────────────────────────────────────
# Secret names used in SecretsService:
#   blissful/razorpay   →  {"key_id": "...", "key_secret": "..."}
#   blissful/flask      →  {"secret_key": "..."}
#   blissful/ses        →  {"from_email": "..."}
# If Secrets Manager is not configured, the service reads from env vars above.

# ── Razorpay Payments (if NOT using Secrets Manager) ─────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Hotel Contact Info ────────────────────────────────────────────────────────
HOTEL_NAME=Blissful Abodes Chennai
HOTEL_PHONE=+91-XXXXXXXXXX
HOTEL_EMAIL=info@blissfulabodes.com
HOTEL_ADDRESS=123 Marina Beach Road, Chennai - 600001

# ── CloudWatch (Feature 12) ───────────────────────────────────────────────────
# SNS Topic ARN for CloudWatch alarm notifications (optional):
CLOUDWATCH_ALARM_SNS_ARN=arn:aws:sns:us-east-1:491694398940:blissful-abodes-alerts
